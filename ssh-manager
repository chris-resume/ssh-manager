_lookup() {
    # output machine's IP address and hostname

    host_exit_status=0
    lookup=$(host -- "$Hostname" 2>/dev/null | grep -Em 1 ' (has address|domain name pointer) ') \
        || host_exit_status=$?

    if [[ $host_exit_status -eq 0 ]]; then

        lookup_answer=$(grep -Eo '[^ ]+$' <<< $lookup)
        if [[ ${lookup_answer: -1} == . ]]; then
            lookup_ip=$Hostname
            lookup_dns=${lookup_answer%?}
        else
            lookup_ip=$lookup_answer
            lookup_dns=$(grep -Eo '^[^ ]+' <<< $lookup)
        fi

        echo
        echo -ne '\e[1mIP: \e[0m  '
        printf '%s\n' "$lookup_ip"
        echo -ne '\e[1mDNS:\e[0m  '
        printf '%s\n' "$lookup_dns"
        echo

    else

        >&2 echo -e '\n\e[3m(failed)\e[0m\n'
        exit 255

    fi

    return 0
}

_ping() {
    # ping machine

    ping -- "$Hostname"

    return 0
}

_rsync() {
    # copy files to or from machine with rsync

    if [[ $Bash == true ]]; then

        while :; do
            >&2 echo 'Copy to or from? [t/f]'
            IFS= read -rp "$read_prompt" rsync_how

            if [[ $rsync_how =~ ^[Tt] ]]; then
                is_rsync_to=1
                rsync_part_one=
                rsync_part_two=$Username@$Hostname:
            elif [[ $rsync_how =~ ^[Ff] ]]; then
                is_rsync_to=0
                rsync_part_one=$Username@$Hostname:
                rsync_part_two=
            else
                >&2 echo -e '\n\e[1mWARNING: Illegal answer!\e[0m\n'
                continue
            fi
            break
        done

        ## ask for source path
        while :; do
            __show_working_directory
            if [[ $is_rsync_to == 1 ]]; then
                rsync_what=()
                >&2 echo 'Copy what? (local path) [.]'
                IFS= read -rep "$read_prompt_readline_multiple" _rsync_what_raw
                if [[ $_rsync_what_raw ]]; then
                    while IFS= read -rd '' _rsync_what_tmp; do
                        rsync_what+=("$_rsync_what_tmp")
                    done < <(__unescape_shell_multiple "$_rsync_what_raw")
                    wait $!
                    if [[ ${#rsync_what[@]} -eq 0 ]]; then
                        >&2 echo -e '\n\e[1mWARNING: No source path provided!\e[0m\n'
                        continue
                    fi
                else
                    rsync_what=(.)
                fi
            else
                rsync_what=
                >&2 echo 'Copy what? (remote path) [~/]'
                IFS= read -rep "$read_prompt_readline_single" rsync_what
                if [[ $rsync_what ]]; then
                    if [[ $rsync_what == '~' || ${rsync_what::2} == '~/' ]]; then
                        rsync_what=\\$rsync_what
                    fi
                    rsync_what=$(__unescape_shell_single "$rsync_what")
                    if [[ -z $rsync_what ]]; then
                        >&2 echo -e '\n\e[1mWARNING: No source path provided!\e[0m\n'
                        continue
                    fi
                    rsync_what=("$rsync_what")
                else
                    rsync_what=('~/')
                fi
            fi
            break
        done

        ## ask for destination path
        while :; do
            rsync_where=
            __show_working_directory
            if [[ $is_rsync_to == 0 ]]; then
                >&2 echo 'Copy where? (local path) [.]'
                IFS= read -rep "$read_prompt_readline_single" rsync_where
                rsync_where=$(__unescape_shell_single "$rsync_where")
                if [[ -z $rsync_where ]]; then
                    rsync_where=.
                    break
                fi
            else
                >&2 echo 'Copy where? (remote path) [~]'
                IFS= read -rep "$read_prompt_readline_single" rsync_where
                if [[ $rsync_where == '~' || ${rsync_where::2} == '~/' ]]; then
                    rsync_where=\\$rsync_where
                fi
                rsync_where=$(__unescape_shell_single "$rsync_where")
                if [[ -z $rsync_where ]]; then
                    rsync_where='~'
                    break
                fi
            fi
            if [[ -z $rsync_where ]]; then
                >&2 echo -e '\n\e[1mWARNING: No destination path provided!\e[0m\n'
                continue
            fi
            break
        done

        if [[ $is_rsync_to == 1 ]]; then
            _rsync_where_tmp=$rsync_part_two$rsync_where
            _rsync_preview_tmp=("${rsync_what[@]@Q}" "${_rsync_where_tmp@Q}")
        else
            _rsync_what_tmp=$rsync_part_one${rsync_what[0]}
            _rsync_preview_tmp=("${_rsync_what_tmp@Q}" "${rsync_where@Q}")
        fi
        _rsync_preview=$' rsync \e[3m[opts]\e[0m '${_rsync_preview_tmp[*]}

        __show_working_directory
        >&2 echo -e '\n\e[1mINFO: Command preview:\e[0m'
        printf '%s\n' "$_rsync_preview"
        >&2 echo -e '\nProceed? [y/N]'
        IFS= read -rp "$read_prompt" rsync_proceed

        if [[ $is_keyfile_present == 0 ]]; then
            _shell_escaped_Port=${Port@Q}
            rsync_cmd=(sshpass -p "$Password" rsync -aPh -e "ssh -p $_shell_escaped_Port" -- "$rsync_part_one${rsync_what[@]}" "$rsync_part_two$rsync_where")
        else
            _shell_escaped_Port=${Port@Q}
            _shell_escaped_Keyfile=${Keyfile@Q}
            rsync_cmd=(rsync -aPh -e "ssh -p $_shell_escaped_Port -i $_shell_escaped_Keyfile" -- "$rsync_part_one${rsync_what[@]}" "$rsync_part_two$rsync_where")
        fi

        # run rsync
        if [[ $rsync_proceed =~ ^[Yy] ]]; then

            until
                >&2 echo
                "${rsync_cmd[@]}"
            do
                >&2 echo -e '\n\e[1mWARNING: Failure transfering files! Retrying rsync indefinitely…\e[0m'
                sleep 2
            done

        else

            >&2 echo -e '\n\e[1mINFO: Aborting.\e[0m'
            exit 0

        fi

    else

        >&2 echo -ne '\e[1mERROR: Bash is `\e[0m'
        >&2 printf %s 'false'
        >&2 echo -e '\e[1m`!\e[0m'
        exit 255

    fi

    return 0
}

_x2go() {
    # connect to machine with X2Go

    x2go_sudo_Username=$Username

    if [[ $Sudo == true ]]; then

        if [[ $Bash == true ]]; then

            ## generate temporary X2Go SSH key if nonexistent
            x2go_private_key_file=$script_generic_dir/$script_generic_name.x2go.key
            x2go_public_key_file=$x2go_private_key_file.pub

            if [[ ! -f $x2go_private_key_file || ! -f $x2go_public_key_file ]]; then
                >&2 echo -e '\n\e[1mINFO: Generating X2Go SSH key pair…\e[0m\n'
                _lock_create
                rm -f "$x2go_private_key_file" "$x2go_public_key_file"
                ssh-keygen -t rsa -b 4096 -f "$x2go_private_key_file" -C x2go-temp -N ''
                chmod 400 "$x2go_private_key_file" "$x2go_public_key_file"
                _lock_remove
            fi

            ## get usernames for autocompletion
            >&2 echo -e '\n\e[1mINFO: Getting user list…\e[0m'

            x2go_remote_users=()
            if \
                x2go_remote_passwd_file=$(
                    2>/dev/null "${ssh_command[@]}" -p "$Port" -t -- "$Username@$Hostname" \
                        'cat /etc/passwd'
                )
            then
                while IFS= read -r _x2go_remote_passwd_file_entry; do
                    _x2go_remote_passwd_file_entry_uid=$(cut -d : -f 3 <<< $_x2go_remote_passwd_file_entry) \
                        && if [[ $_x2go_remote_passwd_file_entry_uid =~ ^[0-9]+$ && $_x2go_remote_passwd_file_entry_uid -ge 1000 && $_x2go_remote_passwd_file_entry_uid -lt 65534 ]]; then
                            _x2go_remote_passwd_file_entry_username=${_x2go_remote_passwd_file_entry%%:*}
                            if [[ ! $_x2go_remote_passwd_file_entry_username =~ / ]]; then
                                x2go_remote_users+=("$_x2go_remote_passwd_file_entry_username")
                            fi
                        fi
                done <<< $x2go_remote_passwd_file
            else
                >&2 echo -e '\n\e[1mWARNING: Failure getting user list from machine!\e[0m'
            fi

            x2go_tmp_dir=${TMPDIR:-/tmp}
            x2go_tmp_dir=$(mktemp -p "$x2go_tmp_dir" -d "_$script_generic_name.x2go.XXXXXXXXXX")
            x2go_tmp_dir=$(realpath -s -- "$x2go_tmp_dir")

            trap 'rm -rf "$x2go_tmp_dir" ; if [[ $BASH_SUBSHELL -eq 0 ]]; then >&2 echo -e "\n\e[1mERROR: Unexpected issue!\e[0m" ; exit 255; fi' ERR
            trap 'rm -rf "$x2go_tmp_dir" ; >&2 echo -e "\n\e[1mERROR: Signal interrupt!\e[0m" ; exit 255' HUP TERM
            trap 'rm -rf "$x2go_tmp_dir" ; >&2 echo -e "\n\e[1mINFO: User interrupt.\e[0m" ; exit 0' INT
            cd "$x2go_tmp_dir"

            ## ask for username with autocompletion
            if [[ ${#x2go_remote_users[@]} -gt 0 ]]; then
                touch -- "${x2go_remote_users[@]}"
                >&2 echo ; ls --color=never -A ; >&2 echo
            else
                >&2 echo -e '\n\e[3m(none found)\e[0m\n'
            fi
            >&2 echo "Username? [$x2go_sudo_Username]"
            IFS= read -rep "$read_prompt_readline_single" Username

            if [[ $Username ]]; then
                if [[ ${Username::1} == '~' ]]; then
                    Username=\\$Username
                fi
                Username=$(__unescape_shell_single "$Username")
                if [[ $Username == root ]]; then
                    >&2 echo -e '\n\e[1mERROR: Refusing to connect with X2Go as root!\e[0m'
                    exit 255
                fi
            else
                Username=$x2go_sudo_Username
            fi
            cd "$OLDPWD"

            ## ask for session type
            >&2 echo "Session type? [$Default__X2Go_Session_Type]"
            IFS= read -rp "$read_prompt" X2Go_Session_Type_answer
            if [[ $X2Go_Session_Type_answer ]]; then
                X2Go_Session_Type=$X2Go_Session_Type_answer
            else
                X2Go_Session_Type=$Default__X2Go_Session_Type
            fi

            >&2 echo
            x2go_public_key=$(cat "$x2go_public_key_file")
            _shell_escaped_Password=${Password@Q}

            ## helper function to remove temporary X2Go SSH key from machine
            __key_machine_remove() {

                >&2 echo -e '\n\e[1mINFO: Removing temporary SSH key from the machine…\e[0m\n'

                _shell_escaped_Username=${Username@Q} &&
                _sed_substitute_keyword_escaped_x2go_public_key=$(__escape_sed_substitute_keyword "$x2go_public_key") &&
                _shell_double_quote_escaped_sed_substitute_keyword_x2go_public_key=$(__escape_shell_double_quote "$_sed_substitute_keyword_escaped_x2go_public_key") &&

                "${ssh_command[@]}" -p "$Port" -t -- "$x2go_sudo_Username@$Hostname" \
                    "id -- $_shell_escaped_Username >/dev/null && printf '%s\n' $_shell_escaped_Password | sudo -Sv 2>/dev/null && sudo -Hu $_shell_escaped_Username bash -c \"[[ -d ~ ]] && sed -i -- /^$_shell_double_quote_escaped_sed_substitute_keyword_x2go_public_key$/d ~/.ssh/authorized_keys\"" &&

                >&2 echo -e '\n\e[1mINFO: Removed temporary SSH key from the machine.\e[0m'

            }

            ## on error, remove temporary X2Go SSH key from machine, and machine's temporary X2Go directory
            trap 'if [[ $BASH_SUBSHELL -eq 0 ]]; then >&2 echo -e "\n\e[1mERROR: X2Go: Will attempt to remove temporary SSH key from the machine…\e[0m" ; __key_machine_remove || >&2 echo -e "\n\e[1mERROR: Failure removing temporary SSH key from the machine!\e[0m" ; rm -rf "$x2go_tmp_dir" ; >&2 echo -e "\n\e[1mERROR: X2Go: Unexpected issue!\e[0m" ; exit 255; fi' ERR

            ## place X2Go SSH key on machine temporarily
            >&2 echo -e '\e[1mINFO: Placing temporary SSH key on the machine…\e[0m\n'

            _shell_escaped_Username=${Username@Q}
            _shell_double_quote_escaped_x2go_public_key=$(__escape_shell_double_quote "$x2go_public_key")

            _lock_create

            "${ssh_command[@]}" -p "$Port" -t -- "$x2go_sudo_Username@$Hostname" \
            "id -- $_shell_escaped_Username >/dev/null && printf '%s\n' $_shell_escaped_Password | sudo -Sv 2>/dev/null && sudo -Hu $_shell_escaped_Username bash -c \"[[ -d ~ ]] && chmod -- go-w ~/ && if [[ -d ~/.ssh ]]; then chmod -- 700 ~/.ssh/; else mkdir -m 700 -- ~/.ssh; fi && if [[ -f ~/.ssh/authorized_keys ]]; then chmod -- 600 ~/.ssh/authorized_keys && if [[ -s ~/.ssh/authorized_keys ]]; then v=\\\$(tail -c 1 -- ~/.ssh/authorized_keys) && if [[ \\\$v ]]; then echo >> ~/.ssh/authorized_keys; fi; else install -Tm 600 -- /dev/null ~/.ssh/authorized_keys; fi; fi && printf '%s\n' $_shell_double_quote_escaped_x2go_public_key >> ~/.ssh/authorized_keys\"" \
                || { >&2 echo -e '\n\e[1mERROR: Failure placing temporary SSH key on the machine!\e[0m' ; rm -rf "$x2go_tmp_dir" ; exit 255; }

            _lock_remove

            >&2 echo -e '\n\e[1mINFO: Placed temporary SSH key on the machine.\e[0m\n'

            ## prepare X2Go config file
            x2go_config=(
                "[$Hostname]"
                'autologin=true'
                'clipboard=both'
                "command=$X2Go_Session_Type"
                'fullscreen=false'
                'height=1080'
                "host=$Hostname"
                "key=$x2go_private_key_file"
                "name=$Machine"
                'print=false'
                'sound=false'
                "sshport=$Port"
                "user=$Username"
                'width=1920'
            )

            x2go_config_file=$(mktemp -p "$x2go_tmp_dir" x2go-config.XXXXXXXXXX)
            printf '%s\n' "${x2go_config[@]}" > "$x2go_config_file"

            ## run X2Go
            x2goclient --no-autoresume --hide --user="$Username" --sessionid="$Hostname" --session-conf="$x2go_config_file"

            ## remove temporary X2Go SSH key from machine
            __key_machine_remove

            ## remove temporary X2Go directory
            rm -rf "$x2go_tmp_dir"

        else

            >&2 echo -ne '\n\e[1mERROR: Bash is `\e[0m'
            >&2 printf %s 'false'
            >&2 echo -e '\e[1m`!\e[0m'
            exit 255

        fi

    else

        >&2 echo -ne '\n\e[1mERROR: Sudo is `\e[0m'
        >&2 printf %s 'false'
        >&2 echo -e '\e[1m`!\e[0m'
        exit 255

    fi

    return 0
}

_uncache() {
    # remove machine from cache

    _sed_substitute_keyword_escaped_Machine=$(__escape_sed_substitute_keyword "$Machine")
    sed -i "/^$_sed_substitute_keyword_escaped_Machine$/d" "$cache_file"

    return 0
}

_clrcache() {
    # clear cache

    > "$cache_file"

    return 0
}

####################################################################################################

# get machine name and/or perform select actions based on fzf choice
if [[ -z $Machine ]]; then
    _choose
else
    >&2 echo -e ' --== \e[1m(PASSED)\e[0m ==--\n'
    _edit
fi

case $action in
    new)
        Machine=
        header_space=
        ;;
    uncache)
        _lock_create
        _uncache
        _lock_remove
        exec "$this_script"
        ;;
    clrcache)
        _lock_create
        _clrcache
        _lock_remove
        exec "$this_script"
        ;;
    *)
        header_space=' '
        ;;
esac

>&2 echo $' --== \e[1m['"${action^^}"$']\e[0m'"$header_space$Machine ==--"

# perform select actions based on fzf choice
case $action in
    ssh)
        _lock_create
        _get_credentials
        _lock_remove
        _ssh
        ;;
    edit)
        >&2 echo
        _edit
        ;;
    new)
        _edit
        ;;
    info)
        _lock_create
        _get_credentials
        _lock_remove
        _info
        ;;
    lookup)
        __command_check host
        _lock_create
        _get_credentials
        _lock_remove
        _lookup
        ;;
    ping)
        __command_check ping
        _lock_create
        _get_credentials
        _lock_remove
        trap - INT
        _ping
        ;;
    rsync)
        __command_check rsync
        _lock_create
        _get_credentials
        _lock_remove
        >&2 echo
        _rsync
        ;;
    x2go)
        __command_check x2goclient
        _lock_create
        _get_credentials
        _lock_remove
        _x2go
        ;;
    *)
        false
        ;;
esac

# exit
exit 0
